<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
  <persistence-unit name="queuectl-persistence" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>com.queuectl.infra.db.entity.Job</class>
    <class>com.queuectl.infra.db.entity.DlqEntry</class>
    <class>com.queuectl.infra.db.entity.Config</class>
    <class>com.queuectl.infra.db.entity.Worker</class>
    <class>com.queuectl.infra.db.entity.Control</class>
    <properties>
      <property name="hibernate.hbm2ddl.auto" value="none"/>
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="false"/>
      <property name="hibernate.jdbc.time_zone" value="UTC"/>
    </properties>
  </persistence-unit>
</persistence>
